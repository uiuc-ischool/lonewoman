  "paragraphs": [
    [
      {
        "text": "The ",
        "tropes": [
          14
        ]
      },
      {
        "text": "wild Indian woman",
        "tropes": [
          14
        ],
        "entity_key": "lw",
        "entity_type": "person"
      },
      {
        "text": "who was found on ",
        "tropes": [
          14
        ]
      },
      {
        "text": "the Island of San Nicholas",
        "tropes": [
          14
        ],
        "entity_key": "i_sn",
        "entity_type": "place"
      },
      {
        "text": ", about seventy miles from ",
        "tropes": [
          14
        ]
      },
      {
        "text": "the coast",
        "tropes": [
          14
        ],
        "entity_key": "re_socalcoast",
        "entity_type": "place"
      },
      {
        "text": ", west of ",
        "tropes": [
          14
        ]
      },
      {
        "text": "Santa Barbara",
        "tropes": [
          14
        ],
        "entity_key": "ci_sb",
        "entity_type": "place"
      },
      {
        "text": ", is now at ",
        "tropes": [
          14
        ]
      },
      {
        "text": "the latter place",
        "tropes": [
          14
        ],
        "entity_key": "ci_sb",
        "entity_type": "place"
      },
      {
        "text": ", and is looked upon as a curiosity. It is stated that she has been some eighteen to twenty years alone on ",
        "tropes": [
          14
        ]
      },
      {
        "text": "the Island",
        "tropes": [
          14
        ],
        "entity_key": "i_sn",
        "entity_type": "place"
      },
      {
        "text": ". She existed on shell fish and the fat of the seal, and dressed in the skins and feathers of wild ducks, which she sewed together with the sinews of the seal. She cannot speak any known language—is good-looking, and about a middle age.",
        "tropes": [
          14
        ]
      },
      {
        "text": "She seems to be contented in her new home among the good people of "
      },
      {
        "text": "Santa Barbara",
        "entity_key": "ci_sb",
        "entity_type": "place"
      },
      {
        "text": "."
      }
    ]
  ]
