{
  "article_id": "ProceedingsOfTheCAoS1857",
  "paragraphs": [
    [
      {
        "text": "President in the Chair."
      }
    ],
    [
      {
        "text": "Prof. Asa Gray",
        "entity_key": "agray",
        "entity_type": "person"
      },
      {
        "text": ", of"
      },
      {
        "text": "Cambridge, Mass",
        "entity_key": "ci_ca",
        "entity_type": "place"
      },
      {
        "text": "., and"
      },
      {
        "text": "Dr. John Torry",
        "entity_key": "jto",
        "entity_type": "person"
      },
      {
        "text": ", of"
      },
      {
        "text": "New York",
        "entity_key": "ci_nyc",
        "entity_type": "place"
      },
      {
        "text": ", were elected Honorary Members."
      }
    ],
    [
      {
        "text": "Dr. John Browne",
        "entity_key": "jbrow",
        "entity_type": "person"
      },
      {
        "text": ", of the U. S. steamer"
      },
      {
        "text": "Active",
        "entity_key": "sh_active",
        "entity_type": "ship"
      },
      {
        "text": ","
      },
      {
        "text": "Mr. Geo. Gibbs",
        "entity_key": "ggibbs",
        "entity_type": "person"
      },
      {
        "text": ", of"
      },
      {
        "text": "Port Townsend",
        "entity_key": "ci_ptown",
        "entity_type": "place"
      },
      {
        "text": ","
      },
      {
        "text": "M. Moreenhaut",
        "entity_key": "more",
        "entity_type": "person"
      },
      {
        "text": ", of"
      },
      {
        "text": "Monterey",
        "entity_key": "ci_mo",
        "entity_type": "place"
      },
      {
        "text": ","
      },
      {
        "text": "Capt. Fauntleroy",
        "entity_key": "faunt",
        "entity_type": "person"
      },
      {
        "text": ","
      },
      {
        "text": "Capt. Wilson",
        "entity_key": "wilson2",
        "entity_type": "person"
      },
      {
        "text": "and"
      },
      {
        "text": "Dr. George Suckley",
        "entity_key": "gsuck",
        "entity_type": "person"
      },
      {
        "text": ", were elected Corresponding Members."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Capt. J. D. Brown",
        "entity_key": "jdbrown",
        "entity_type": "person"
      },
      {
        "text": ", of the schooner"
      },
      {
        "text": "Ada",
        "entity_key": "sh_ada",
        "entity_type": "ship"
      },
      {
        "text": ", specimens of Reptiles, Fishes, Annelida and Crustacea, from the"
      },
      {
        "text": "Gulf of California",
        "entity_key": "re_calgulf",
        "entity_type": "place"
      },
      {
        "text": "."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Dr. Pigne Dupuytren",
        "entity_key": "dup",
        "entity_type": "person"
      },
      {
        "text": ", a fine collection of Marine Shells and a skull of Belone, from"
      },
      {
        "text": "New Caledonia",
        "entity_key": "i_ncal",
        "entity_type": "place"
      },
      {
        "text": "; also, a fabric made from the hair of the bat, by the natives of those islands."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Dr. Welch",
        "entity_key": "welch",
        "entity_type": "person"
      },
      {
        "text": ", a skull of Diomedea chlororynchos, and a skull of a native of the"
      },
      {
        "text": "Sandwich Islands",
        "entity_key": "i_san",
        "entity_type": "place"
      },
      {
        "text": "."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Dr. Czapkay",
        "entity_key": "cza",
        "entity_type": "person"
      },
      {
        "text": ", a large species of Patella."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Mr. Parent",
        "entity_key": "parent",
        "entity_type": "person"
      },
      {
        "text": ", two specimens of Chiton and a Cularis, from the"
      },
      {
        "text": "Gallipagos [Galápagos] Islands",
        "entity_key": "i_galli",
        "entity_type": "place"
      },
      {
        "text": "."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Mr. H. P. Wakelee",
        "entity_key": "hwak",
        "entity_type": "person"
      },
      {
        "text": ", a suite of specimens from"
      },
      {
        "text": "Nicaragua",
        "entity_key": "co_nic",
        "entity_type": "place"
      },
      {
        "text": ", consisting of the capsule of Cocoa Bean, Scorpion, skin of a large serpent, (called by the natives Bo-bo,) and Coal; also, Copper smelted at the La Miua del Padre, ("
      },
      {
        "text": "Colima",
        "entity_key": "ci_colima",
        "entity_type": "place"
      },
      {
        "text": ".) [sic] and Copper Ore from La Mina Truxcanisco, ("
      },
      {
        "text": "Colima",
        "entity_key": "ci_colima",
        "entity_type": "place"
      },
      {
        "text": "); also, Solar Salt from near"
      },
      {
        "text": "Los Angeles, Cal.",
        "entity_key": "ci_la",
        "entity_type": "place"
      },
      {
        "text": "; also Auriferous Quartz from"
      },
      {
        "text": "Kern river",
        "entity_key": "re_kern",
        "entity_type": "place"
      },
      {
        "text": ", and a shell of Echinus."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Mr. H. R Bloomer",
        "entity_key": "bloom",
        "entity_type": "person"
      },
      {
        "text": ", a specimen of Eutainia dorsalis, from"
      },
      {
        "text": "San Francisco",
        "entity_key": "ci_sf",
        "entity_type": "place"
      },
      {
        "text": "."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Barry",
        "entity_key": "barry",
        "entity_type": "person"
      },
      {
        "text": "&"
      },
      {
        "text": "Patten",
        "entity_key": "patten",
        "entity_type": "person"
      },
      {
        "text": ", s [a] specimen of Ornothorynchus, from"
      },
      {
        "text": "Australia",
        "entity_key": "co_aus",
        "entity_type": "place"
      },
      {
        "text": "."
      }
    ],
    [
      {
        "text": "The thanks of"
      },
      {
        "text": "the Academy",
        "entity_key": "mu_calacademyofscience",
        "entity_type": "org"
      },
      {
        "text": "were voted for the donations above recorded."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Dr. Lanszweert",
        "entity_key": "lansz",
        "entity_type": "person"
      },
      {
        "text": ", Liguite, from"
      },
      {
        "text": "Sonoma",
        "entity_key": "ci_son",
        "entity_type": "place"
      },
      {
        "text": "."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Dr. Bennett",
        "entity_key": "bennett",
        "entity_type": "person"
      },
      {
        "text": ", a specimen of Gypsum, and one of native Alum, from"
      },
      {
        "text": "Guaymas.",
        "entity_key": "ci_guaymas",
        "entity_type": "place"
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Capt. Russell",
        "entity_key": "cru",
        "entity_type": "person"
      },
      {
        "text": ", a fine specimen of Yucca, in full bloom, from"
      },
      {
        "text": "the Southern Coast",
        "entity_key": "re_socalcoast",
        "entity_type": "place"
      },
      {
        "text": "; also, two young specimens of the same for cultivation; also, several specimens of Mesembryanthemum."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Dr. Kellogg",
        "entity_key": "kellogg",
        "entity_type": "person"
      },
      {
        "text": ", a specimen of Scolopendra, from"
      },
      {
        "text": "Monte Diatolo",
        "entity_key": "re_mdiatolo",
        "entity_type": "place"
      },
      {
        "text": "; also, a box of seeds."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Dr. Ayres",
        "entity_key": "wayres",
        "entity_type": "person"
      },
      {
        "text": ", a specimen of Anarrhicthys ocellatus, and one of Cebidichthys crista galli, from"
      },
      {
        "text": "San Francisco Bay",
        "entity_key": "re_sfbay",
        "entity_type": "place"
      },
      {
        "text": "."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Mr. W. M. Pease",
        "entity_key": "wpease",
        "entity_type": "person"
      },
      {
        "text": ", of"
      },
      {
        "text": "Honolulu",
        "entity_key": "ci_hon",
        "entity_type": "place"
      },
      {
        "text": ", a fine suite of specimens from the"
      },
      {
        "text": "Sandwich Islands",
        "entity_key": "i_san",
        "entity_type": "place"
      },
      {
        "text": ", consisting of Crustacea, Land and Marine Shells, Echinoderms and Corals."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Mr. Hepburn",
        "entity_key": "hepburn",
        "entity_type": "person"
      },
      {
        "text": ", Calcareous Travertine, from"
      },
      {
        "text": "the Geysers",
        "entity_key": "re_geysers",
        "entity_type": "place"
      },
      {
        "text": "."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Mr. Beardslee",
        "entity_key": "beards",
        "entity_type": "person"
      },
      {
        "text": ", a specimen of Trillium."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Dr. George Suckley",
        "entity_key": "gsuck",
        "entity_type": "person"
      },
      {
        "text": ", specimens of Mytilus, from the"
      },
      {
        "text": "Straits of Fuca",
        "entity_key": "re_fuca",
        "entity_type": "place"
      },
      {
        "text": "."
      }
    ],
    [
      {
        "text": "From"
      },
      {
        "text": "Dr. Trask",
        "entity_key": "trask",
        "entity_type": "person"
      },
      {
        "text": ", a specimen of Nereis, thirty-three inches in length, from"
      },
      {
        "text": "San Francisco Bay",
        "entity_key": "re_sfbay",
        "entity_type": "place"
      },
      {
        "text": "; also, a fish allied to Gunnellus, of apparently a new generic type; also, a quantity of the ripe fruit of the Coffee Tree, from the"
      },
      {
        "text": "Sandwich Islands",
        "entity_key": "i_san",
        "entity_type": "place"
      },
      {
        "text": ". The curators were requested to distribute these seeds throughout"
      },
      {
        "text": "the State",
        "entity_key": "st_cal",
        "entity_type": "place"
      },
      {
        "text": "for the purpose of inducing their cultivation."
      }
    ],
    [
      {
        "text": "Capt. Russell",
        "entity_key": "cru",
        "entity_type": "person"
      },
      {
        "text": "deposited a Water Bottle and Beads, with a Mortar, which were made by"
      },
      {
        "text": "the Indian woman Maria",
        "entity_key": "lw",
        "entity_type": "person"
      },
      {
        "text": ", on"
      },
      {
        "text": "the Island of San Nicolas",
        "entity_key": "i_sn",
        "entity_type": "place"
      },
      {
        "text": ", during her solitary residence there of eighteen years."
      }
    ]
  ]
}