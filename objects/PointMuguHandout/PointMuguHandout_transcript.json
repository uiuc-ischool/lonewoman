      {
        "text": "JUANA MARIA",
        "entity_key": "lw",
        "entity_type": "person"
      }
    ],
    [
      {
        "text": "INDIAN WOMAN",
        "entity_key": "lw",
        "entity_type": "person"
      },
      {
        "text": " ABANDONED ON "
